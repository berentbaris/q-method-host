# Q-Method Server — Email Configuration
# Copy this file to .env and fill in your SMTP details.
# If SMTP_HOST is not set, emails are printed to the console instead.

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Q-Sort Platform <noreply@yourdomain.com>"

# For Resend (https://resend.com):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key
# SMTP_FROM="Q-Sort <onboarding@resend.dev>"
