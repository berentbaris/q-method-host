# ---- Database (optional) ----
# SQLite database file path. Default: server/data/qmethod.db
# DB_PATH=./server/data/qmethod.db

# ---- Email (optional) ----
# If SMTP_HOST is not set, result emails are printed to the console instead.
# This lets you run the app in "demo mode" without configuring a mail provider.

# Gmail example (use an App Password, not your real password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Q-Sort <yourname@gmail.com>"

# Resend example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key
# SMTP_FROM="Q-Sort <noreply@yourdomain.com>"
